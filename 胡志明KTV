<html lang="zh-TW"><head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>胡志明 KTV 類型指南｜華人 KTV、薄紗風格、禮服風格一次看懂</title>
    <meta name="description" content="整理胡志明三種常見 KTV 類型,快速看懂風格差異、預算概念與避坑提醒,適合第一次到胡志明的華語旅客。">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Noto Sans TC', sans-serif;
            background: #0a0a0a;
            color: #e0e0e0;
            line-height: 1.6;
            overflow-x: hidden;
        }

        html {
            scroll-behavior: smooth;
        }

        :root {
            --primary-black: #1a1a1a;
            --gold: #d4af37;
            --dark-gray: #2a2a2a;
            --neon-cyan: #00d4ff;
            --light-gray: #e0e0e0;
            --border-color: rgba(212, 175, 55, 0.2);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Navigation */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(26, 26, 26, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }

        .navbar.scrolled {
            box-shadow: 0 4px 20px rgba(212, 175, 55, 0.1);
        }

        .nav-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .nav-logo {
            font-size: 20px;
            font-weight: 700;
            color: var(--gold);
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .nav-links a {
            color: var(--light-gray);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s ease;
            font-weight: 500;
        }

        .nav-links a:hover {
            color: var(--gold);
        }

        /* Hero Section */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0a0a0a 100%);
            overflow: hidden;
            padding-top: 80px;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 50%, rgba(0, 212, 255, 0.05) 0%, transparent 50%);
            animation: pulse 8s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        .hero-content {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 900px;
            padding: 40px 20px;
        }

        .hero-title {
            font-size: clamp(32px, 6vw, 56px);
            font-weight: 700;
            color: var(--gold);
            margin-bottom: 20px;
            letter-spacing: 2px;
            text-shadow: 0 0 30px rgba(212, 175, 55, 0.3);
        }

        .hero-subtitle {
            font-size: clamp(16px, 3vw, 20px);
            color: var(--light-gray);
            margin-bottom: 40px;
            line-height: 1.8;
            font-weight: 300;
        }

        .hero-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .btn {
            padding: 14px 32px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-block;
            border: 2px solid;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--gold);
            color: #1a1a1a;
            border-color: var(--gold);
        }

        .btn-primary:hover {
            background: transparent;
            color: var(--gold);
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: var(--light-gray);
            border-color: var(--light-gray);
        }

        .btn-secondary:hover {
            background: var(--light-gray);
            color: #1a1a1a;
        }

        .disclaimer {
            font-size: 13px;
            color: #888;
            font-style: italic;
            margin-top: 20px;
        }

        /* Section Styling */
        .section {
            padding: 80px 0;
            position: relative;
        }

        .section-title {
            font-size: clamp(28px, 5vw, 40px);
            font-weight: 700;
            color: var(--gold);
            text-align: center;
            margin-bottom: 60px;
            letter-spacing: 1px;
        }

        /* KTV Cards */
        .ktv-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }

        .ktv-card {
            background: linear-gradient(135deg, var(--primary-black) 0%, var(--dark-gray) 100%);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 32px;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .ktv-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--gold), var(--neon-cyan));
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }

        .ktv-card:hover::before {
            transform: scaleX(1);
        }

        .ktv-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 40px rgba(212, 175, 55, 0.2);
            border-color: var(--gold);
        }

        .ktv-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }

        .ktv-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--gold), #f4d03f);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .ktv-card-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--gold);
        }

        .ktv-info {
            margin-bottom: 20px;
        }

        .ktv-info-item {
            margin-bottom: 16px;
            display: flex;
            gap: 8px;
        }

        .ktv-info-label {
            font-weight: 600;
            color: var(--neon-cyan);
            min-width: 80px;
        }

        .ktv-info-text {
            color: var(--light-gray);
            flex: 1;
        }

        .budget-badge {
            display: inline-block;
            padding: 6px 16px;
            background: rgba(212, 175, 55, 0.15);
            border: 1px solid var(--gold);
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
            color: var(--gold);
            margin-top: 16px;
        }

        /* Comparison Table */
        .comparison-table {
            background: var(--primary-black);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            margin-top: 40px;
        }

        .comparison-table table {
            width: 100%;
            border-collapse: collapse;
        }

        .comparison-table th {
            background: var(--dark-gray);
            color: var(--gold);
            padding: 20px 16px;
            text-align: left;
            font-weight: 600;
            border-bottom: 2px solid var(--border-color);
        }

        .comparison-table td {
            padding: 20px 16px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
            color: var(--light-gray);
        }

        .comparison-table tr:last-child td {
            border-bottom: none;
        }

        .comparison-table tr:hover {
            background: rgba(212, 175, 55, 0.05);
        }

        .rating {
            display: flex;
            gap: 4px;
        }

        .rating-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--gold);
        }

        .rating-dot.empty {
            background: rgba(212, 175, 55, 0.2);
        }

        /* Warning Cards */
        .warning-badge {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, #ff4444, #cc0000);
            color: white;
            font-weight: 700;
            border-radius: 24px;
            margin-bottom: 40px;
            font-size: 16px;
            letter-spacing: 1px;
        }

        .warning-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-top: 40px;
        }

        .warning-card {
            background: linear-gradient(135deg, var(--primary-black), var(--dark-gray));
            border: 2px solid rgba(255, 68, 68, 0.3);
            border-radius: 12px;
            padding: 24px;
            display: flex;
            gap: 16px;
            align-items: flex-start;
            transition: all 0.3s ease;
        }

        .warning-card:hover {
            border-color: #ff4444;
            box-shadow: 0 8px 24px rgba(255, 68, 68, 0.2);
        }

        .warning-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 68, 68, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 20px;
        }

        .warning-text {
            color: var(--light-gray);
            font-size: 15px;
            line-height: 1.6;
        }

        /* Steps */
        .steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-top: 40px;
        }

        .step {
            position: relative;
            text-align: center;
            padding: 32px 24px;
            background: var(--primary-black);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            transition: all 0.3s ease;
        }

        .step:hover {
            border-color: var(--gold);
            transform: translateY(-4px);
        }

        .step-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--gold), #f4d03f);
            color: #1a1a1a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 700;
            margin: 0 auto 20px;
        }

        .step-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--gold);
            margin-bottom: 12px;
        }

        .step-text {
            color: var(--light-gray);
            font-size: 14px;
        }

        /* FAQ */
        .faq-container {
            max-width: 800px;
            margin: 40px auto 0;
        }

        .faq-item {
            background: var(--primary-black);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            margin-bottom: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .faq-item:hover {
            border-color: var(--gold);
        }

        .faq-question {
            padding: 24px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            user-select: none;
        }

        .faq-question-text {
            font-size: 17px;
            font-weight: 600;
            color: var(--light-gray);
            flex: 1;
        }

        .faq-icon {
            width: 28px;
            height: 28px;
            background: var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1a1a1a;
            font-weight: 700;
            transition: transform 0.3s ease;
            flex-shrink: 0;
        }

        .faq-item.active .faq-icon {
            transform: rotate(45deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease;
        }

        .faq-answer-content {
            padding: 0 24px 24px 24px;
            color: #aaa;
            line-height: 1.8;
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, var(--dark-gray), var(--primary-black));
            border: 2px solid var(--border-color);
            border-radius: 20px;
            padding: 60px 40px;
            text-align: center;
            margin-top: 40px;
        }

        .cta-title {
            font-size: clamp(24px, 4vw, 36px);
            font-weight: 700;
            color: var(--gold);
            margin-bottom: 20px;
        }

        .cta-text {
            font-size: 18px;
            color: var(--light-gray);
            margin-bottom: 40px;
            line-height: 1.8;
        }

        .cta-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        /* Footer */
        .footer {
            background: var(--primary-black);
            border-top: 1px solid var(--border-color);
            padding: 40px 20px;
            text-align: center;
            margin-top: 80px;
        }

        .footer-text {
            color: #888;
            font-size: 14px;
            line-height: 2;
            margin-bottom: 8px;
        }

        /* Floating Button */
        .floating-btn {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 999;
            background: linear-gradient(135deg, var(--gold), #f4d03f);
            color: #1a1a1a;
            padding: 16px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 16px;
            box-shadow: 0 8px 24px rgba(212, 175, 55, 0.4);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .floating-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(212, 175, 55, 0.6);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }

            .hero {
                min-height: 90vh;
            }

            .section {
                padding: 60px 0;
            }

            .ktv-cards {
                grid-template-columns: 1fr;
            }

            .comparison-table {
                overflow-x: auto;
            }

            .comparison-table table {
                min-width: 600px;
            }

            .steps {
                grid-template-columns: 1fr;
            }

            .cta-section {
                padding: 40px 24px;
            }

            .floating-btn {
                bottom: 16px;
                right: 16px;
                padding: 14px 20px;
                font-size: 14px;
            }
        }

        /* Kuse Branding */
        .kuse-branding {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            color: #888;
            font-size: 13px;
            text-decoration: none;
            transition: all 0.3s ease;
            margin-top: 40px;
        }

        .kuse-branding:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

        .kuse-branding svg {
            height: 1.2em;
            width: auto;
        }
    </style>
