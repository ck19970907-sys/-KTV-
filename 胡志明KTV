          }
        },
        {
          "@type": "Question",
          "name": "去完之後怎麼安全返回住宿?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "優先使用 Grab 或店家配合的正規車隊,不要隨意上陌生人的車。酒後更要注意安全,建議結伴同行,並提前告知住宿地點給信任的朋友。"
          }
        }
      ]
    }
